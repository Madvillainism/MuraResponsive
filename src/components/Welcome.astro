---
import mura from "../assets/mura.webp";
import Navbar from "./Navbar.astro";
import { Icon } from "astro-icon/components";
import Footer from "./Footer.astro";
---

<Navbar />
<main>
  <div id="hero-container">
    <h1>
      Good things are<br />
      made with <b>LOVE</b>
    </h1>

    <p>
      Lorem ipsum dolor sit amet consectetur adipisicing elit. Accusamus
      architecto repellat dignissimos! Neque debitis quidem distinctio dolorum
      obcaecati dignissimos mollitia.
    </p>

    <div id="buttons">
      <a href="/about-us">Ver Productos</a>
      <a>Realizar Pedido</a>
    </div>
    <img src={mura.src} alt="purple man" class="hero-img" />
  </div>

  <section>
    <div>
      <h1>Projects</h1>
      <p>
        Lorem ipsum dolor sit amet consectetur adipisicing elit. Accusamus
        architecto repellat dignissimos! Neque debitis quidem distinctio dolorum
        obcaecati dignissimos mollitia.
      </p>
      <a> View projects </a>
      <article id="card-container">
        <div class="card">
          <h2>Diseños de sonrisa</h2>
          <p>Lorem ipsum dolor sit amet consectetur adipisicing elit.</p>
        </div>
        <div class="card">
          <h2>Implantes dentales</h2>
          <p>Lorem ipsum dolor sit amet consectetur adipisicing elit.</p>
        </div>
        <div class="card">
          <h2>Ortodoncia invisible</h2>
          <p>Lorem ipsum dolor sit amet consectetur adipisicing elit.</p>
        </div>
      </article>
    </div>

    <article id="experience-container">
      <section id="stats-container">
        <div>
          <h2>+150</h2>
          <p>Clientes satisfechos</p>
        </div>
        <div>
          <h2>+25</h2>
          <p>Clientes satisfechos</p>
        </div>
      </section>
      <div class="box">
        <h2>+3.000</h2>
        <p>Casos atendidos</p>
      </div>
      <img src={mura.src} alt="experiencia" class="experience-img" />
    </article>
  </section>

  <section id="testimonials-container">
    <h1>Testimonios</h1>
    <p>
      Lorem ipsum dolor sit amet consectetur adipisicing elit. Accusamus
      architecto repellat dignissimos! Neque debitis quidem distinctio dolorum
      obcaecati dignissimos mollitia.
    </p>
    <a>Conocer Más</a>
  </section>

  <section id="contact-container">
    <!-- <div>
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d12631.720583863775!2d-4.9280177499999995!3d37.674349150000005!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0xd6d304ff47e5eb5%3A0x2541347cae15d3b5!2sMercadona!5e0!3m2!1sen!2ses!4v1768596711754!5m2!1sen!2ses"
        width="400"
        height="350"
        style="border:0; margin-top:64px;"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"></iframe>
    </div> -->
    <section id="contact-info">
      <Icon class="other-icon" name="material-symbols:location-on" />
      <div>
        <h3>Teléfono</h3>
        <p>0424-696-7524</p>
      </div>
    </section>
    <section id="contact-info">
      <Icon name="material-symbols:location-on" />
      <div>
        <h3>Teléfono</h3>
        <p>0424-696-7524</p>
      </div>
    </section>
  </section>

  <section id="form-container">
    <h1>¡Llamame el jueves!</h1>

    <p>
      ¡Estamos disponibles para responder cualquier duda que tengas! Respondemos
      dentro de las 24 horas.
    </p>

    <div id="icons-container">
      <Icon name="mdi:facebook" />
      <Icon name="mdi:linkedin" />
      <Icon name="mdi:instagram" />
    </div>

    <article id="schedule-container">
      <section>
        <h2>Horario</h2>
        <p>xd</p>
      </section>
      <section>
        <h2>Dirección</h2>
        <p>xd</p>
      </section>
    </article>
    <form>
      <input type="text" placeholder="Nombre" />
      <input type="text" placeholder="Correo" />
      <input type="text" placeholder="Mensaje" />
      <button>Enviar</button>
    </form>
  </section>
</main>

<Footer />

<style>
  main {
    width: auto;
  }

  .hero-img {
    width: 300px;
    height: 350px;
  }

  #hero-container {
    padding: 0 16px;
    padding-top: 64px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;

    h1 {
      color: var(--white);
      margin: 0;
    }

    p {
      width: 90%;
      text-align: center;
      color: var(--white);
    }
  }

  #buttons {
    display: flex;
    gap: 16px;
  }

  a {
    padding: 0.5em;
    border-radius: 12px;
    text-decoration: none;
    text-align: center;
    color: var(--black);
    background-color: var(--green);
    border: 2px solid var(--green);
    cursor: pointer;
    width: 10em;
    font-size: 1rem;
    box-shadow:
      0 10px 20px rgba(0, 0, 0, 0.19),
      0 6px 6px rgba(0, 0, 0, 0.23);
  }

  button:nth-child(2) {
    background-color: transparent;
    color: var(--white);
  }

  section {
    background-color: var(--white);
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: 0 16px;

    p {
      text-wrap: balance;
    }

    #card-container {
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      gap: 2em;
      margin-top: 20%;
    }

    .card {
      align-items: flex-start;
      border-radius: 12px;
      display: flex;
      flex-direction: column;
      gap: 16px;
      height: 10em;
      justify-content: flex-end;
      padding: 1em;
      width: 90%;

      h2 {
        color: var(--white);
        font-size: 1.5rem;
        margin: 0;
      }

      p {
        color: var(--white);
        margin: 0;
      }
    }

    .card:nth-child(1) {
      background-color: var(--purple);
    }

    .card:nth-child(2) {
      background-color: var(--green);
    }

    .card:nth-child(3) {
      background-color: var(--black);
    }

    #experience-container {
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      gap: 16px;
      padding-top: 64px;
      width: 90%;

      div {
        background-color: var(--green);
        border: none;
        border-radius: 12px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        padding: 0.5em;
        height: 8em;
        width: 90%;

        h2 {
          font-size: 1.75rem;
          margin: 0;
        }

        p {
          margin: 0;
        }
      }
      .box {
        width: 90%;
      }
    }

    #stats-container {
      display: flex;
      flex-direction: row;
      justify-content: center;
      align-items: center;
      gap: 16px;
      width: 90%;
    }

    .experience-img {
      width: 320px;
      height: 80%;
    }
  }

  #testimonials-container {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    gap: 16px;
    padding-bottom: 2em;
  }

  #contact-container {
    background-image: url("../assets/map.webp");
    display: flex;
    flex-direction: row;
    background-size: cover;
    background-repeat: no-repeat;
    justify-content: center;
    align-items: flex-end;
    background-position: center;
    gap: 16px;
    height: 500px;
  }

  #contact-info {
    display: flex;
    flex-direction: row;
    justify-content: center;
    align-items: center;
    gap: 16px;
    border: 1px solid var(--black);
    border-radius: 12px;
    padding: 0.5em;

    [data-icon] {
      vertical-align: middle;
      padding: 0.5em;
      border-radius: 50%;
      border: none;
      background-color: var(--green);
    }

    h3 {
      margin: 0;
    }

    p {
      margin: 0;
      font-size: 0.8rem;
    }
  }

  #form-container {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    height: auto;
    gap: 16px;
    padding-top: 2em;
    h1,
    p {
      text-align: left;
      margin: 0;
    }

    #icons-container {
      display: flex;
      flex-direction: row;
      gap: 1em;

      [data-icon] {
        vertical-align: middle;
        padding: 0.5em;
        border-radius: 50%;
        border: none;
        background-color: var(--green);
        font-size: 1.5em;
      }
    }

    #schedule-container {
      display: flex;
      flex-direction: row;
      width: 100%;
      gap: 1em;
    }

    form {
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: flex-start;
      gap: 1em;
      width: 100%;
    }

    input {
      border-radius: 12px;
      border: none;
      padding: 0.5em;
      height: 2em;
      width: 90%;
    }
    input:nth-child(3) {
      height: 6em;
      resize: none;
    }
  }

  @media screen and (min-width: 768px) and (max-width: 1024px) {
    h1 {
      font-size: 3rem;
    }
    #hero-container {
      display: flex;
      flex-direction: column;
    }

    button {
      font-size: 1.25rem;
    }

    #hero {
      display: block;
      padding-top: 10%;
    }
  }
</style>
